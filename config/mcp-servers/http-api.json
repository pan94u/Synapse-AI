{
  "id": "http-api",
  "name": "HTTP API Server",
  "description": "Generic REST API proxy",
  "transport": "stdio",
  "command": "bun",
  "args": ["run", "packages/mcp-servers/src/http-api/index.ts"],
  "env": {
    "HTTP_API_BASE_URL": "${env:HTTP_API_BASE_URL}",
    "HTTP_API_AUTH_HEADER": "${env:HTTP_API_AUTH_HEADER}",
    "HTTP_API_AUTH_VALUE": "${env:HTTP_API_AUTH_VALUE}"
  },
  "enabled": false,
  "autoStart": false,
  "healthCheck": {
    "interval": 30000,
    "timeout": 5000,
    "retries": 3
  },
  "rateLimit": {
    "maxRequests": 60,
    "windowMs": 60000
  },
  "permissions": {
    "tools": ["http_request"],
    "resources": ["*"],
    "requireApproval": []
  },
  "tags": ["http", "rest", "api"],
  "category": "infrastructure"
}
