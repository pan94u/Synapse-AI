{
  "id": "erp",
  "name": "ERP Server",
  "description": "运营/供应链管理（库存、订单、采购、生产）",
  "transport": "stdio",
  "command": "bun",
  "args": ["run", "packages/mcp-servers/src/erp/index.ts"],
  "env": {},
  "enabled": true,
  "autoStart": true,
  "healthCheck": {
    "interval": 30000,
    "timeout": 5000,
    "retries": 3
  },
  "rateLimit": {
    "maxRequests": 100,
    "windowMs": 60000
  },
  "permissions": {
    "tools": ["erp_query_inventory", "erp_list_orders", "erp_get_procurement", "erp_get_production"],
    "resources": ["*"],
    "requireApproval": []
  },
  "tags": ["erp", "inventory", "order", "procurement", "production"],
  "category": "erp"
}
