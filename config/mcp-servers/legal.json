{
  "id": "legal",
  "name": "Legal Server",
  "description": "法务合同管理（合同、合规、审批）",
  "transport": "stdio",
  "command": "bun",
  "args": ["run", "packages/mcp-servers/src/legal/index.ts"],
  "env": {},
  "enabled": true,
  "autoStart": true,
  "healthCheck": {
    "interval": 30000,
    "timeout": 5000,
    "retries": 3
  },
  "rateLimit": {
    "maxRequests": 100,
    "windowMs": 60000
  },
  "permissions": {
    "tools": ["legal_search_contracts", "legal_get_contract", "legal_check_compliance", "legal_list_approvals"],
    "resources": ["*"],
    "requireApproval": []
  },
  "tags": ["legal", "contract", "compliance", "approval"],
  "category": "legal"
}
